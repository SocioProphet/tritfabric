def write_onnx_check(artifacts_root: str, job_id: str, trial_id: str, ok: bool, sim: float, thr: float, path: str):\
    import os, json, time\
    outdir = os.path.join(artifacts_root, job_id)\
    os.makedirs(outdir, exist_ok=True)\
    obj = \{"ok": ok, "cos_sim": sim, "threshold": thr, "onnx_path": path, "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ")\}\
    with open(os.path.join(outdir, f"\{trial_id\}_onnx_check.json"), "w") as f:\
        json.dump(obj, f, indent=2)\
    # optionally, also include inside a consolidated ledger envelope:\
    with open(os.path.join(outdir, "onnx_check.json"), "w") as f:\
        json.dump(obj, f, indent=2)\

