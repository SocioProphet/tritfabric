\f0\b\fs40 \cf0 7) Minimal code sketch (Riemannian Stiefel layer)\
\pard\pardeftab560\sa40\partightenfactor0

\fs32 \cf0 class StiefelLinear(nn.Module):\
    # W 
\f6\b0 \uc0\u8712 
\f0\b  Stiefel(n, k): orthonormal columns\
    def __init__(self, n, k, bias=True):\
        super().__init__()\
        Q, _ = torch.linalg.qr(torch.randn(n, k))\
        self.W = nn.Parameter(Q)             # constrained weight\
        self.b = nn.Parameter(torch.zeros(n)) if bias else None\
\
    @torch.no_grad()\
    def retract(self):\
        # Cayley or QR retraction back to Stiefel\
        Q, _ = torch.linalg.qr(self.W)\
        self.W.copy_(Q)\
\
    def forward(self, x):\
        y = x @ self.W\
        return y + (self.b if self.b is not None else 0.0)\
\pard\pardeftab560\slleading20\partightenfactor0

\f1\b0\fs26 \cf0 (Wrap with an optimizer that calls 
\f0\b\fs32 retract()
\f1\b0\fs26  after each step; use geoopt for full Riemannian updates.)\
\
\pard\pardeftab560\partightenfactor0

