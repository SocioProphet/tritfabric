\f4 \uc0\u8594 
\f1 \uc0\u956 \u952 .\
\ls381\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 CFG: \'ea = (1+s)\uc0\u949 _cond \u8722  s \u949 _uncond.\
