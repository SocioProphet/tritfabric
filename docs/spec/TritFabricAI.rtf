\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 train-nouns.sh (whole noun hierarchy) ({\field{\*\fldinst{HYPERLINK "https://github.com/facebookresearch/poincare-embeddings?utm_source=chatgpt.com"}}{\fldrslt \ul GitHub}}).\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls94\ilvl0
