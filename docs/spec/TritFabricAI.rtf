\f4 \uc0\u10003 
\f1  + ONNX cosine 
\f4 \uc0\u10003 
\f1  + eval deltas 
\f4 \uc0\u10003 
\f1 .\
\ls55\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 Canary decision = 
\f0\b SLOs AND gates
\f1\b0  (not either).\
