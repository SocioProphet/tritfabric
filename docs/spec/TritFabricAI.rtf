\f6 \uc0\u8855 
\f1  1 \uc0\u8722  1 
\f6 \uc0\u8855 
\f1  w_write^t) 
\f6 \uc0\u8857 
\f1  L^\{t\uc0\u8722 1\} + w_write^t 
\f6 \uc0\u8855 
\f1  p^\{t\uc0\u8722 1\}.\
