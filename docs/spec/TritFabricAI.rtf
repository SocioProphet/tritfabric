\f0\b\fs40 \cf0 1) Fixes (turned into concrete, reusable knobs)\
\pard\pardeftab560\sa40\partightenfactor0

\fs32 \cf0 1.1 CNN-LoRA that actually works (plus IA\'b3 for convs)\
\pard\pardeftab560\slleading20\partightenfactor0

\fs26 \cf0 LoRA for conv
\f1\b0 : add a low-rank residual to a target conv\'92s weight. We bias to 
\f0\b 1\'d71 A
\f1\b0  then 
\f0\b k\'d7k B
\f1\b0  so we\'92re rank-r but retain spatial expressivity.\
# slate/peft/lora_conv.py\
import torch.nn as nn\
class LoRAConv2d(nn.Module):\
    def __init__(self, base: nn.Conv2d, rank=8, alpha=1.0):\
        super().__init__()\
        self.base = base\
        C_out, C_in, K, K2 = base.weight.shape\
        self.lora_A = nn.Conv2d(C_in, rank, 1, bias=False)      # 1x1 shrink\
        self.lora_B = nn.Conv2d(rank, C_out, K, padding=K//2, bias=False)  # kxk expand\
        nn.init.kaiming_uniform_(self.lora_A.weight, a=5**0.5)\
        nn.init.zeros_(self.lora_B.weight)\
        self.scaling = alpha / rank\
        for p in self.base.parameters(): p.requires_grad = False\
    def forward(self, x):\
        return self.base(x) + self.scaling * self.lora_B(self.lora_A(x))\

\f0\b IA\'b3-style multiplicative adapters for conv
\f1\b0  (ultra cheap): learn per-channel gates you multiply into activations around target convs.\
# slate/peft/ia3_conv.py\
class IA3Gate2d(nn.Module):\
    def __init__(self, channels, where="post"):  # "pre" or "post"\
        super().__init__()\
        self.where = where\
        self.g = nn.Parameter(torch.ones(1, channels, 1, 1))\
    def forward(self, x, conv_out=None):\
        return x*self.g if self.where=="pre" else conv_out*self.g\

\f0\b Policy
\f1\b0 : for ResNet/ConvNeXt we target the 
\f0\b last stage
\f1\b0  (e.g., layer4.*.conv3) with LoRA rank 4-16; for memory-starved devices use 
\f0\b IA\'b3
\f1\b0  only. This is fully pluggable in the IR:\
peft:\
  lora:\
    targets: ["backbone.layer4.*.conv3"]\
    rank: 8\
  ia3:\
    targets: ["backbone.layer4.*.relu"]   # gate post-activation\
\pard\pardeftab560\sa40\partightenfactor0

\f0\b\fs32 \cf0 1.2 Better KD (less peaky teachers)\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls305\ilvl0
\f2\b0\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Temperature
\f1\b0 : set T=2\'964; we expose 
\f0\b per-batch adaptive T
\f1\b0 : if max softmax > \uc0\u964  (e.g., 0.9), bump T to soften.\
\ls305\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 \uc0\u945  schedule
\f1\b0 : start with \uc0\u945 =0.95 (soft dominates), cosine-anneal to 0.8 by end.\
\ls305\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Top-k logits
\f1\b0 : keep top-k (e.g., 32) teacher logits to save IO; reconstruct a sparse soft target.\
\ls305\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Label smoothing
\f1\b0  on student hard CE (\uc0\u949 =0.1) to avoid overfit.\
\pard\pardeftab560\slleading20\partightenfactor0
\cf0 def kd_loss(student, teacher, labels, T, alpha, k=0):\
    import torch.nn.functional as F\
    if k>0:\
        t = teacher.clone()\
        topk = torch.topk(t, k, dim=-1).indices\
        mask = torch.zeros_like(t).scatter_(1, topk, 1.)\
        t = torch.where(mask>0, t, torch.full_like(t, -1e9))\
    soft = F.kl_div(F.log_softmax(student/T, dim=-1),\
                    F.softmax(teacher/T, dim=-1),\
                    reduction="batchmean") * (T*T)\
    hard = F.cross_entropy(student, labels, label_smoothing=0.1)\
    return alpha*soft + (1-alpha)*hard\
\pard\pardeftab560\sa40\partightenfactor0

\f0\b\fs32 \cf0 1.3 Safe task-vector merging\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls306\ilvl0
\f2\b0\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f1\fs26 Require 
\f0\b arch & tokenizer match
\f1\b0 ; otherwise first 
\f0\b align embeddings
\f1\b0  (e.g., Procrustes on shared tokens) and 
\f0\b skip non-matching keys
\f1\b0 .\
\ls306\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Per-layer \uc0\u945 
\f1\b0 : down-weight earlier layers, up-weight heads\'97reduces regressions.\
\pard\pardeftab560\slleading20\partightenfactor0
\cf0 def layerwise_alpha(name):\
    if "embeddings" in name or "stem" in name: return 0.25\
    if "layer1" in name: return 0.4\
    if "layer2" in name: return 0.6\
    if "layer3" in name: return 0.8\
    if "layer4" in name or "head" in name: return 1.0\
    return 0.5\
def apply_vector(target_sd, delta):\
    out = target_sd.copy()\
    for k, dv in delta.items():\
        if k in out and out[k].shape == dv.shape:\
            out[k] = out[k] + layerwise_alpha(k) * dv\
    return out\
\pard\pardeftab560\sa40\partightenfactor0

\f0\b\fs32 \cf0 1.4 RLHF on LMs that fits a laptop\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls307\ilvl0
\f2\b0\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 QLoRA
\f1\b0  (nf4/norm-aware) + 
\f0\b paged optimizers
\f1\b0  (bitsandbytes) + 
\f0\b LoRA on attention proj
\f1\b0  only.\
\ls307\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Tiny reward model
\f1\b0  (distilled BERT-base classifier or 110M DeBERTa).\
\ls307\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 Short 
\f0\b seq_len (\uc0\u8804 512)
\f1\b0 , 
\f0\b micro-batches (\uc0\u8804 4)
\f1\b0 , gradient-accumulation to reach nominal batch.\
\ls307\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 PPO defaults that don\'92t explode: KL-penalty 0.02\'960.1, clip=0.2, vf_coef=0.5, ent_coef=0.01, target-KL 0.01\'960.02.\
\pard\pardeftab560\slleading20\partightenfactor0
