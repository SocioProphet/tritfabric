\f1\fs26 Iteratively update b_ij 
\f4 \uc0\u8592 
\f1  b_ij + \'fb_j|i\'b7v_j.\
\ls387\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Tune knobs
