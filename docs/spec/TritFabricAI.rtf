\f1\b0\fs26 \cf0 # Stage 1: teacher inference\
teacher = build_teacher(ckpt=...)\
ds = ray.data.read_images("~/.zoo_slate/data/myset").map_batches(\
    lambda b: \{"logits": teacher(b["image"]).cpu().numpy(), "label": b["label"]\},\
    batch_size=32, num_gpus=1)\
ds.write_parquet("~/.zoo_slate/kd/myset/teacher_logits")\
\
# Stage 2: student trains from parquet\
train_ds = ray.data.read_parquet("~/.zoo_slate/kd/myset/teacher_logits")\
trainer = TorchTrainer(train_loop_per_worker=student_loop, datasets=\{"train": train_ds\}, ...)\
