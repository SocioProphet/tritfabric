\f0\b\fs40 \cf0 C) Transfer learning: from others\'92 weights to your local fine-tune\
\pard\pardeftab560\slleading20\partightenfactor0

\f1\b0\fs26 \cf0 We support 
\f0\b three routes
\f1\b0 , all local-friendly:\
\pard\pardeftab560\partightenfactor0

\f0\b\fs40 \cf0 C.1 Parameter-Efficient Fine-Tuning (PEFT)\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls298\ilvl0
\f2\b0\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 LoRA/QLoRA
\f1\b0  (attention/conv projections); 
\f0\b Adapters
\f1\b0 ; 
\f0\b BitFit
\f1\b0  (bias-only).\
\ls298\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 Train only ~0.1\'962% of params; tiny VRAM; great for laptops.\
\pard\pardeftab560\sa40\partightenfactor0

\f0\b\fs32 \cf0 from slate.peft.lora_attn import add_lora_to_attn\
model = AutoModel.from_pretrained("bert-base-uncased")\
for p in model.parameters(): p.requires_grad = False\
add_lora_to_attn(model, rank=8, targets=("query","value"))\
# optimizer only sees LoRA params\
opt = torch.optim.AdamW([p for p in model.parameters() if p.requires_grad], lr=1e-4)\
