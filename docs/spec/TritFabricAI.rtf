\fs26 \cf0 QLoRA
\f1\b0 : load model in 
\f0\b nf4
\f1\b0  quantized weights (bitsandbytes), train LoRA modules only (for larger LMs).\
\pard\pardeftab560\partightenfactor0

\f0\b\fs40 \cf0 C.2 Knowledge Distillation (KD) \'97 learn from others\'92 logits/features\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls299\ilvl0
\f2\b0\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Supervised KD
\f1\b0 : teacher logits 
\f4 \uc0\u8594 
\f1  student cross-entropy with temperature + hard labels.\
\ls299\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Feature KD
\f1\b0 : MSE between teacher & student intermediate features (match dims with 1\'d71 conv).\
\ls299\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Offline KD on Ray Data
\f1\b0 : teacher generates logits once, saved to Parquet 
\f4 \uc0\u8594 
\f1  student trains offline, local.\
\pard\pardeftab560\sa40\partightenfactor0

\f0\b\fs32 \cf0 # slate/distill/distill_step.py\
def kd_loss(student_logits, teacher_logits, T=2.0, alpha=0.8, labels=None):\
    import torch.nn.functional as F\
    soft = F.kl_div(\
        F.log_softmax(student_logits/T, dim=-1),\
        F.softmax(teacher_logits/T, dim=-1),\
        reduction="batchmean"\
    ) * (T*T)\
    hard = F.cross_entropy(student_logits, labels) if labels is not None else 0.0\
    return alpha*soft + (1-alpha)*hard\
\pard\pardeftab560\slleading20\partightenfactor0

