class ServeServicer(atlas_pb2_grpc.ServeServiceServicer):\
    ...\
    def RouterSticky(self, req, ctx):\
        router = serve.get_deployment("Router").get_handle()\
        import ray\
        # keep existing weights/shadow; just toggle sticky\
        st = ray.get(router.status.remote())\
        res = ray.get(router.update.remote(st.get("weights", \{\}), bool(st.get("shadow", False)), bool(req.sticky)))\
        return atlas_pb2.Status(state="ROUTER_STICKY_SET", info=\{"sticky": str(res.get("sticky", False))\})\

