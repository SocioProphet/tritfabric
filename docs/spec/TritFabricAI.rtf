\f0\b\fs40 \cf0 Notes on layer-math alignment & ops\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl0
\f2\b0\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Padding
\f1\b0 :\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl1
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f1\fs26 "same" 
\f4 \uc0\u8594 
\f1  pad = 
\f2 \uc0\u8970 
\f1 (k\uc0\u8722 1)/2
\f2 \uc0\u8971 
\f1  (keeps spatial size for stride=1).\
\ls371\ilvl1
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 "valid" 
\f4 \uc0\u8594 
\f1  pad = 0 (shrinks spatial size).\
\ls371\ilvl1
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 Ensure anchors/ASPP rates still align to feature maps when changing padding/stride.\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl0
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Stride vs dilation
\f1\b0 :\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl1
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f1\fs26 Increasing 
\f0\b stride
\f1\b0  downsamples; increasing 
\f0\b dilation
\f1\b0  enlarges receptive field without downsampling (holes).\
\ls371\ilvl1
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 For DeepLab, higher output_stride reduces dilation, and vice-versa.\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl0
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Attention heads
\f1\b0 :\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl1
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f1\fs26 head_dim = d_model / n_heads (keep divisible).\
\ls371\ilvl1
\f2\fs18 {\listtext	\uc0\u8226 	}
\f1\fs26 Q/K/V dims should be aligned; LoRA target lists pick query|value projections.\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl0
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Normalization
\f1\b0 :\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl1
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 BN
\f1\b0 : prefer eps=1e-5, momentum\uc0\u8776 0.1 for ResNets; if changed, reset stats + warmup.\
\ls371\ilvl1
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 LN
\f1\b0 : transformer/ConvNeXt; eps=1e-6-ish default.\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl0
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Residual depth
\f1\b0 :\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl1
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f1\fs26 stage_depths controls number of bottleneck blocks per stage; deeper models need DropPath.\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl0
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Decoder choice
\f1\b0 :\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl1
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f1\fs26 Prefer interpolate+1\'d71 over deconv to avoid checkerboards; only use deconv when geometry learning is required.\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl0
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 RNN dropout
\f1\b0 :\
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls371\ilvl1
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f1\fs26 Use 
\f0\b variational dropout
\f1\b0  (fixed mask per sequence) for input/recurrent links; zoneout 0.05 for stability.\
\pard\pardeftab560\slleading20\partightenfactor0
