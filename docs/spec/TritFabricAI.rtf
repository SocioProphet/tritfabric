def launch_trials(self, job_id: str, req: Dict):\
    pg = self._mk_pg(req.get("resources", \{\}))\
    ray.get(pg.ready())\
    try:\
        ...\
        result = tuner.fit()\
        self._collect_ledgers(job_id, result)\
        # Auto-promotion based on policy threshold\
        thresh = self.policy.doc.get("scheduler",\{\}).get("auto_promotion",\{\}).get("metric_threshold", None)\
        if thresh is not None:\
            best = result.get_best_result()\
            metric_name = req.get("metric", "val_acc")\
            if best.metrics.get(metric_name, float("-inf")) >= float(thresh):\
                card = self.registry.promote(\
                    job_id, req,\
                    \{"metrics": best.metrics\}\
                )\
                print("[PROMOTE]", \{"job_id": job_id, "metric": metric_name, "value": best.metrics.get(metric_name), "threshold": thresh, "card": card\})\
        return result\
    finally:\
        remove_placement_group(pg)\

