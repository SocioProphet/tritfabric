\f1\b0 \
\pard\pardeftab560\slleading20\partightenfactor0
\cf0 helm install tritfabric-server charts/tritfabric-server \\\
  --set image.repository=ghcr.io/$ORG/tritfabric-server \\\
  --set image.tag=latest\
Or use the existing 
