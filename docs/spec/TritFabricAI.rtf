\fs26 \cf0 Math mapping
\f1\b0 \
\pard\pardeftab560\pardirnatural\partightenfactor0
\ls368\ilvl0
\f2\fs18 \cf0 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Conv
\f1\b0 : y = Conv(W, x; k, s, pad, dilation) + b; tuning k, dilation, pad changes RF & aliasing.\
\ls368\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 BN
\f1\b0 : y = (x - \uc0\u956 )/sqrt(\u963 \'b2+\u949 ) * \u947  + \u946 ; eps avoids div-by-0, momentum controls running stats.\
\ls368\ilvl0
\f2\fs18 {\listtext	\uc0\u8226 	}
\f0\b\fs26 Residual
\f1\b0 : y = F(x) + x stabilizes gradients across layers.\
\pard\pardeftab560\slleading20\partightenfactor0
