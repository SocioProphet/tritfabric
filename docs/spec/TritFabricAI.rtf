\f1\b0\fs26 \cf0 # configs/retina_local.yaml\
model:\
  family: retina\
  backbone: resnet50\
  neck: fpn\
  head: retina\
  frozen: [backbone, neck]\
norm: batchnorm\
act: relu\
\
peft:\
  lora: \{ targets: ["backbone.layer4.*.conv3"], rank: 8 \}\
  ia3:  \{ targets: [], enabled: false \}\
\
reg:\
  dropout: \{ head_p: 0.1 \}\
  dropblock: \{ enabled: true, block_size: 7, p: 0.10, targets: ["backbone.layer3","backbone.layer4"] \}\
  stochastic_depth: \{ drop_prob: 0.0 \}   # (ConvNeXt=0.1)\
  label_smoothing: 0.0\
\
kd: \{ enabled: false, T: 2.0, alpha: 0.9, topk: 32 \}\
\
train:\
  bs: 8\
  amp: true\
  fsdp: true\
  epochs: 12\
  optim: \{ type: adamw, lr_head: 5e-4, lr_lora: 1e-4, wd: 0.05 \}\
  sched: \{ type: cosine, warmup_steps: 1500 \}\
\
data:\
  source: s3://\'85/coco.parquet  # or file://~/.zoo_slate/coco.parquet\
  preproc: aug/coco_retina.yaml\
\
