FROM python:3.11-slim

WORKDIR /app
COPY pyproject.toml README.md requirements.txt requirements-dev.txt ./
COPY atlas ./atlas
COPY cmd ./cmd
COPY api ./api
COPY slate ./slate
COPY tools ./tools
COPY configs ./configs

RUN python -m pip install -U pip && \
    python -m pip install -e .

EXPOSE 8000 9108
ENV ATLAS_HTTP_HOST=0.0.0.0 ATLAS_HTTP_PORT=8000 ATLAS_METRICS_PORT=9108

CMD ["python", "-m", "cmd.atlasd.main", "--config", "configs/policy.yaml", "--host", "0.0.0.0", "--port", "8000"]
