FROM python:3.11-slim

WORKDIR /app
COPY pyproject.toml README.md requirements.txt ./
COPY atlas ./atlas
COPY tools ./tools
COPY api ./api

RUN python -m pip install -U pip && \
    python -m pip install -e . && \
    python -m pip install pyshacl onnxruntime || true

ENTRYPOINT ["python", "tools/gates_run.py"]
