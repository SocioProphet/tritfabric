FROM python:3.11-slim

WORKDIR /app
COPY pyproject.toml README.md requirements.txt ./
COPY gateways ./gateways
COPY atlas ./atlas

RUN python -m pip install -U pip && \
    python -m pip install fastapi uvicorn sse-starlette requests numpy rdflib pyyaml

EXPOSE 8080
ENV SSE_HOST=0.0.0.0 SSE_PORT=8080

CMD ["uvicorn", "gateways.sse_gateway:app", "--host", "0.0.0.0", "--port", "8080"]
