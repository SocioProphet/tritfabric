{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/schemas/tritfabric/community-workflow.schema.json",
  "title": "Community Learning Workflow",
  "type": "object",
  "required": [
    "id",
    "version",
    "purpose",
    "inputs",
    "gates",
    "steps",
    "outputs",
    "claim_boundary"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+$"},
    "purpose": {"type": "string", "minLength": 1},
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "description"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {
            "type": "string",
            "enum": ["ingest", "policy_check", "curate", "evaluate", "distill", "ab_test", "credit", "emit", "manual_review"]
          },
          "description": {"type": "string", "minLength": 1}
        }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "claim_boundary": {"type": "string", "minLength": 1},
    "notes": {"type": "string"}
  }
}
