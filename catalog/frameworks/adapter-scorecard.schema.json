{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/schemas/tritfabric/adapter-scorecard.schema.json",
  "title": "Network Atlas Adapter Scorecard",
  "type": "object",
  "required": [
    "framework_id",
    "scorecard_version",
    "authority",
    "adapter_scope",
    "readiness",
    "gates",
    "claim_boundary"
  ],
  "additionalProperties": false,
  "properties": {
    "framework_id": {"type": "string", "minLength": 1},
    "scorecard_version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+$"},
    "authority": {
      "type": "string",
      "enum": ["catalog", "adapter", "runtime", "promotion", "deprecated"]
    },
    "adapter_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["training", "serving", "evaluation", "dataset", "conversion", "observability", "none"]
      }
    },
    "readiness": {
      "type": "string",
      "enum": ["not_started", "design_only", "stub", "smoke_tested", "validated", "blocked", "rejected"]
    },
    "gates": {
      "type": "object",
      "required": ["license", "provenance", "tests", "model_card", "runtime_safety"],
      "additionalProperties": false,
      "properties": {
        "license": {"type": "string", "enum": ["unknown", "pass", "review_required", "fail"]},
        "provenance": {"type": "string", "enum": ["unknown", "pass", "review_required", "fail"]},
        "tests": {"type": "string", "enum": ["none", "smoke", "unit", "integration", "conformance"]},
        "model_card": {"type": "string", "enum": ["none", "partial", "complete"]},
        "runtime_safety": {"type": "string", "enum": ["unknown", "pass", "review_required", "fail"]}
      }
    },
    "claim_boundary": {"type": "string", "minLength": 1},
    "notes": {"type": "string"}
  }
}
